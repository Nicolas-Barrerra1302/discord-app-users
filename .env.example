# ============================================
# Nico Barrera Academy — Bot Discord Unificado
# Variables de Entorno
# ============================================
# Copiar este archivo como .env y completar con valores reales:
#   cp .env.example .env

# ── Global ───────────────────────────────────

# Token del bot de Discord
# Obtener en: https://discord.com/developers/applications → Bot → Reset Token
DISCORD_TOKEN=

# Ruta al archivo JSON de credenciales del service account de Google
# Obtener en: Google Cloud Console → IAM → Service Accounts → Keys → Create Key (JSON)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Token de autenticacion para webhooks de Hotmart
# Obtener en: Hotmart → Configuraciones → Webhooks → HOTTOK
HOTTOK=

# Puerto para el servidor Express (endpoints de invites y webhooks)
PORT=3000

# ── Programa A (Proyecto Inversionista Consciente) ──

# ID del servidor de Discord del Programa A
# Obtener: Click derecho en el servidor → Copiar ID del servidor
GUILD_ID_A=

# ID del canal donde se generan las invitaciones del Programa A
# Obtener: Click derecho en el canal → Copiar ID del canal
INVITE_CHANNEL_ID_A=

# IDs de los 2 productos de Hotmart del Programa A
# Obtener en: Hotmart → Productos → copiar ID numerico
HOTMART_PRODUCT_A1=
HOTMART_PRODUCT_A2=

# ID del Google Sheet de miembros del Programa A
# Es el ID largo en la URL: docs.google.com/spreadsheets/d/{ESTE_ID}/edit
SHEET_ID_A=

# URL del webhook de n8n para validar codigos Hotmart del Programa A
# Obtener en: n8n → Workflow "Verificar Compras" → Nodo Webhook → Production URL
N8N_WEBHOOK_A=

# URL del Apps Script que envia emails branded del Programa A
# Obtener en: Apps Script → Deploy → Web app → URL
APPSCRIPT_URL_A=

# Token de autenticacion para el Apps Script del Programa A
# Definido dentro del codigo del Apps Script
APPSCRIPT_TOKEN_A=

# ── Programa B (Creeser) ────────────────────

# ID del servidor de Discord del Programa B
GUILD_ID_B=

# ID del canal de invitaciones del Programa B
INVITE_CHANNEL_ID_B=

# IDs de los 2 productos de Hotmart del Programa B
HOTMART_PRODUCT_B1=
HOTMART_PRODUCT_B2=

# ID del Google Sheet de miembros del Programa B
SHEET_ID_B=

# URL del webhook de n8n del Programa B
N8N_WEBHOOK_B=

# URL del Apps Script del Programa B
APPSCRIPT_URL_B=

# Token del Apps Script del Programa B
APPSCRIPT_TOKEN_B=
